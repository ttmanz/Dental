# ═══════════════════════════════════════════════════════════════════════════
# Dental Assistant Pro — Environment Variables
# Copy this file to .env and fill in every value before starting the server.
# Never commit .env to git — it contains secrets.
# ═══════════════════════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
# Full public URL — used in reset emails and Stripe success/cancel redirects
APP_URL=https://your-domain.com

# ── Database ────────────────────────────────────────────────────────────────
# Option A: single connection string (preferred for managed DBs / Heroku / Railway)
DATABASE_URL=postgres://dental_app:YOUR_DB_PASSWORD@localhost:5432/dental_db

# Option B: individual parts (if DATABASE_URL is not set, db.js falls back to these)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dental_db
DB_USER=dental_app
DB_PASSWORD=change_me

# ── Auth ────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_random_96_char_hex_string
JWT_EXPIRES_IN=8h

# ── Superadmin ──────────────────────────────────────────────────────────────
# One-time secret for POST /api/superadmin/init (create first superadmin)
# After first use the endpoint rejects all requests — keep this safe.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SUPERADMIN_INIT_SECRET=replace_with_random_64_char_hex_string

# ── Stripe ──────────────────────────────────────────────────────────────────
# Keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Webhook signing secret — from Dashboard → Webhooks → your endpoint → Signing secret
# Endpoint URL: https://your-domain.com/api/billing/webhook
# Events to subscribe: checkout.session.completed, customer.subscription.updated,
#   customer.subscription.deleted, invoice.paid, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — run:  node setup-stripe.js  to create these automatically
STRIPE_PRICE_SOLO=price_...       # €49/month — 1 dentist, unlimited patients
STRIPE_PRICE_CLINIC=price_...     # €99/month — up to 5 dentists
STRIPE_PRICE_GROUP=price_...      # €199/month — unlimited dentists + multi-location

# ── Email / SMTP ────────────────────────────────────────────────────────────
# Works with: Mailgun · Brevo (Sendinblue) · SendGrid · AWS SES · Gmail App Password
# Leave blank to skip email (reset links are logged to console instead)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_SECURE=false                 # Set true only for port 465
SMTP_USER=postmaster@mg.your-domain.com
SMTP_PASS=your-mailgun-api-key
EMAIL_FROM=Dental Assistant Pro <noreply@your-domain.com>

# ── WhatsApp Business API ────────────────────────────────────────────────────
# From https://developers.facebook.com → Your App → WhatsApp → API Setup
# Leave blank to disable — app shows a setup guide in the WhatsApp inbox tab.
WA_ACCESS_TOKEN=
WA_PHONE_NUMBER_ID=
# Any string you choose — must match what you configure in Meta webhook settings
WA_VERIFY_TOKEN=
# UUID of your practice (SELECT id FROM practices LIMIT 1) — for inbound routing
DEFAULT_PRACTICE_ID=

# ── CORS ────────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=https://your-domain.com

# ── Claude AI ────────────────────────────────────────────────────────────────
# Per-practice in ai_settings table — not a server secret.
# Each practice enters their own Anthropic API key in the AI settings panel.
# ANTHROPIC_API_KEY is not set here.
